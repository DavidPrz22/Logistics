model lote {
  id               Int                    @id @default(autoincrement())
  varianteId       Int                    
  numeroLote       String
  fechaVencimiento DateTime
  stockActual      Int                    
  fechaIngreso     DateTime?              @default(now()) 
  variante         varianteProducto       @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  detallesOrden    detalleOrden[]
  movimientos      movimientoInventario[]

  @@unique([varianteId, numeroLote])
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

model movimientoInventario {
  id               Int                  @id @default(autoincrement())
  loteId           Int       
  almacenId        Int       
  detalleOrdenId   Int?
  detalleRechazoId Int?

  tipoMovimiento   TipoMovimiento
  cantidad         Int
  fechaMovimiento  DateTime?            @default(now()) 
  referencia       String
  usuarioId        Int  

  detalleOrden     detalleOrden?        @relation(fields: [detalleOrdenId], references: [id], onDelete: SetNull)
  detalleRechazo   detalleRechazoOrden? @relation(fields: [detalleRechazoId], references: [id], onDelete: SetNull)
  lote             lote                 @relation(fields: [loteId], references: [id], onDelete: Restrict)
  almacen          almacen              @relation(fields: [almacenId], references: [id], onDelete: Restrict)
  usuario          usuario              @relation(fields: [usuarioId], references: [id])

  @@unique([detalleOrdenId, loteId])
}
